generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  emailVerified    Boolean          @default(false)
  image            String?
  twoFactorEnabled Boolean?         @default(false)
  roleId           Int?
  companyCode      String?          @default("LEARNIFY")
  status           Int              @default(1)
  isDeleted        Int              @default(0)
  createdBy        String?          @default("SYSTEM")
  createdAt        DateTime         @default(now()) @map("createdDate")
  lastUpdatedBy    String?          @default("SYSTEM")
  updatedAt        DateTime         @default(now()) @updatedAt @map("lastUpdatedDate")
  taughtCourses    Course[]         @relation("InstructorCourses")
  enrollments      Enrollment[]
  invoices         Invoice[]
  progress         LessonProgress[]
  reviews          Review[]
  accounts         account[]
  sessions         session[]
  twoFactor        twoFactor?
  role             Role?            @relation(fields: [roleId], references: [id])

  @@map("user")
}

model twoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String   @unique
  createdAt   DateTime @default(now()) @map("createdDate")
  updatedAt   DateTime @default(now()) @updatedAt @map("lastUpdatedDate")
  verified    Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model session {
  id                String   @id @default(uuid())
  expiresAt         DateTime
  token             String   @unique
  createdAt         DateTime @default(now()) @map("createdDate")
  updatedAt         DateTime @default(now()) @updatedAt @map("lastUpdatedDate")
  ipAddress         String?
  userAgent         String?
  userId            String
  twoFactorVerified Boolean? @default(false)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("createdDate")
  updatedAt             DateTime  @default(now()) @updatedAt @map("lastUpdatedDate")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now()) @map("createdDate")
  updatedAt  DateTime @default(now()) @updatedAt @map("lastUpdatedDate")
}

model Role {
  id              Int      @id @default(autoincrement())
  name            String
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt
  users           User[]
}

model Category {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt
  courses         Course[]
}

model Course {
  id              Int          @id @default(autoincrement())
  instructorId    String
  categoryId      Int
  title           String
  slug            String       @unique
  description     String
  thumbnail       String?
  price           Decimal
  level           String
  isPublished     Boolean      @default(false)
  isPopular       Boolean      @default(false)
  totalLessons    Int          @default(0)
  totalMinutes    Int          @default(0)
  rating          Float        @default(0)
  reviewCount     Int          @default(0)
  companyCode     String       @default("LEARNIFY")
  status          Int          @default(1)
  isDeleted       Int          @default(0)
  createdBy       String       @default("SYSTEM")
  createdDate     DateTime     @default(now())
  lastUpdatedBy   String       @default("SYSTEM")
  lastUpdatedDate DateTime     @updatedAt
  category        Category     @relation(fields: [categoryId], references: [id])
  instructor      User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  tags            CourseTag[]
  enrollments     Enrollment[]
  lessons         Lesson[]
  reviews         Review[]
}

model Lesson {
  id              Int              @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  videoUrl        String?
  duration        Int              @default(0)
  order           Int
  isFree          Boolean          @default(false)
  companyCode     String           @default("LEARNIFY")
  status          Int              @default(1)
  isDeleted       Int              @default(0)
  createdBy       String           @default("SYSTEM")
  createdDate     DateTime         @default(now())
  lastUpdatedBy   String           @default("SYSTEM")
  lastUpdatedDate DateTime         @updatedAt
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress        LessonProgress[]
}

model LessonProgress {
  id              BigInt    @id @default(autoincrement())
  userId          String
  lessonId        Int
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  watchedSecs     Int       @default(0)
  companyCode     String    @default("LEARNIFY")
  status          Int       @default(1)
  isDeleted       Int       @default(0)
  createdBy       String    @default("SYSTEM")
  createdDate     DateTime  @default(now())
  lastUpdatedBy   String    @default("SYSTEM")
  lastUpdatedDate DateTime  @updatedAt
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model CourseTag {
  id              Int      @id @default(autoincrement())
  courseId        Int
  name            String
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id               Int          @id @default(autoincrement())
  userId           String
  courseId         Int
  enrollmentStatus String       @default("active")
  enrolledAt       DateTime     @default(now())
  completedAt      DateTime?
  companyCode      String       @default("LEARNIFY")
  status           Int          @default(1)
  isDeleted        Int          @default(0)
  createdBy        String       @default("SYSTEM")
  lastUpdatedBy    String       @default("SYSTEM")
  createdDate      DateTime     @default(now())
  lastUpdatedDate  DateTime     @updatedAt
  certificate      Certificate?
  course           Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Invoice {
  id              Int           @id @default(autoincrement())
  userId          String
  invoiceNumber   String        @unique
  totalAmount     Decimal
  invoiceStatus   String        @default("pending")
  dueDate         DateTime
  companyCode     String        @default("LEARNIFY")
  status          Int           @default(1)
  isDeleted       Int           @default(0)
  createdBy       String        @default("SYSTEM")
  createdDate     DateTime      @default(now())
  lastUpdatedBy   String        @default("SYSTEM")
  lastUpdatedDate DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  transactions    Transaction[]
}

model Transaction {
  id                Int      @id @default(autoincrement())
  invoiceId         Int
  orderId           String   @unique
  grossAmount       Decimal
  transactionStatus String   @default("pending")
  paymentType       String
  signatureKey      String
  transactionTime   DateTime
  companyCode       String   @default("LEARNIFY")
  status            Int      @default(1)
  isDeleted         Int      @default(0)
  createdBy         String   @default("SYSTEM")
  lastUpdatedBy     String   @default("SYSTEM")
  createdDate       DateTime @default(now())
  lastUpdatedDate   DateTime @updatedAt
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
}

model Certificate {
  id                Int        @id @default(autoincrement())
  enrollmentId      Int        @unique
  certificateNumber String     @unique
  filePath          String?
  issuedDate        DateTime   @default(now())
  companyCode       String     @default("LEARNIFY")
  status            Int        @default(1)
  isDeleted         Int        @default(0)
  createdBy         String     @default("SYSTEM")
  lastUpdatedBy     String     @default("SYSTEM")
  createdDate       DateTime   @default(now())
  lastUpdatedDate   DateTime   @updatedAt
  enrollment        Enrollment @relation(fields: [enrollmentId], references: [id])
}

model Review {
  id              Int      @id @default(autoincrement())
  userId          String
  courseId        Int
  rating          Int
  comment         String?
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
