generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
//  AUTH MODELS — String ID (Better Auth compatibility)
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  twoFactorEnabled Boolean? @default(false)

  // ── Team Standard Fields ──────────────────────────────────────────────────
  roleId          Int?
  companyCode     String?  @default("LEARNIFY")
  status          Int      @default(1)    // 1=aktif, 0=nonaktif
  isDeleted       Int      @default(0)    // 0=ada, 1=terhapus (soft delete)
  createdBy       String?  @default("SYSTEM")
  createdDate      DateTime @default(now())
  lastUpdatedBy   String?  @default("SYSTEM")
  lastUpdatedDate DateTime @default(now()) @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────────
  role          Role?            @relation(fields: [roleId], references: [id])
  sessions      session[]
  accounts      account[]
  enrollments   Enrollment[]
  invoices      Invoice[]
  taughtCourses Course[]         @relation("InstructorCourses")
  progress      LessonProgress[]
  twoFactor     twoFactor?
  reviews       Review[]
  todos         Todo[]
  submissions   Submission[]

  @@map("user")
}

// ── 2FA (TOTP) ────────────────────────────────────────────────────────────────
// Tabel ini dikelola oleh Better Auth twoFactor plugin
// secret      : TOTP secret key (terenkripsi di Better Auth)
// backupCodes : JSON array backup codes untuk akses darurat
model twoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean @default(false)
  createdDate      DateTime @default(now())
  lastUpdatedDate DateTime @default(now()) @updatedAt
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdDate      DateTime @default(now())
  lastUpdatedDate DateTime @default(now()) @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  twoFactorVerified Boolean? @default(false) 
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdDate           DateTime  @default(now())
  lastUpdatedDate       DateTime  @default(now()) @updatedAt
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdDate      DateTime  @default(now())
  lastUpdatedDate DateTime  @default(now()) @updatedAt
}

// ═════════════════════════════════════════════════════════════════════════════
//  BUSINESS MODELS
// ═════════════════════════════════════════════════════════════════════════════

model Role {
  id              Int      @id @default(autoincrement())
  name            String   // "admin" | "instructor" | "student"
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  users User[]
}

model Category {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  courses Course[]
}

model Course {
  id              Int      @id @default(autoincrement())
  instructorId    String
  categoryId      Int
  title           String
  slug            String   @unique
  description     String
  thumbnail       String?
  price           Decimal
  level           String
  isPublished     Boolean  @default(false)
  isPopular       Boolean  @default(false)
  totalLessons    Int      @default(0)
  totalMinutes    Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  instructor  User      @relation("InstructorCourses", fields: [instructorId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])
  lessons     Lesson[]
  enrollments Enrollment[]
  tags        CourseTag[]
  reviews     Review[]
  assignments Assignment[]
  recordings  Recording[]
  resources   Resource[]
  schedules   Schedule[]
}

model Lesson {
  id              Int      @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  videoUrl        String?
  duration        Int      @default(0)
  order           Int
  isFree          Boolean  @default(false)
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
}

model LessonProgress {
  id              BigInt    @id @default(autoincrement())
  userId          String
  lessonId        Int
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  watchedSecs     Int       @default(0)
  companyCode     String    @default("LEARNIFY")
  status          Int       @default(1)
  isDeleted       Int       @default(0)
  createdBy       String    @default("SYSTEM")
  createdDate     DateTime  @default(now())
  lastUpdatedBy   String    @default("SYSTEM")
  lastUpdatedDate DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model CourseTag {
  id              Int      @id @default(autoincrement())
  courseId        Int
  name            String
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id               Int       @id @default(autoincrement())
  userId           String
  courseId         Int
  enrollmentStatus String    @default("active")
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?
  companyCode      String    @default("LEARNIFY")
  status           Int       @default(1)
  isDeleted        Int       @default(0)
  createdBy        String    @default("SYSTEM")
  createdDate      DateTime  @default(now())
  lastUpdatedBy    String    @default("SYSTEM")
  lastUpdatedDate  DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificate Certificate?

  @@unique([userId, courseId])
}

model Invoice {
  id              Int      @id @default(autoincrement())
  userId          String
  invoiceNumber   String   @unique
  totalAmount     Decimal
  invoiceStatus   String   @default("pending")
  dueDate         DateTime
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id                Int      @id @default(autoincrement())
  invoiceId         Int
  orderId           String   @unique
  grossAmount       Decimal
  transactionStatus String   @default("pending")
  paymentType       String
  signatureKey      String
  transactionTime   DateTime
  companyCode       String   @default("LEARNIFY")
  status            Int      @default(1)
  isDeleted         Int      @default(0)
  createdBy         String   @default("SYSTEM")
  createdDate       DateTime @default(now())
  lastUpdatedBy     String   @default("SYSTEM")
  lastUpdatedDate   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Certificate {
  id                Int      @id @default(autoincrement())
  enrollmentId      Int      @unique
  certificateNumber String   @unique
  filePath          String?
  issuedDate        DateTime @default(now())
  companyCode       String   @default("LEARNIFY")
  status            Int      @default(1)
  isDeleted         Int      @default(0)
  createdBy         String   @default("SYSTEM")
  createdDate       DateTime @default(now())
  lastUpdatedBy     String   @default("SYSTEM")
  lastUpdatedDate   DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
}

// ═════════════════════════════════════════════════════════════════════════════
//  REVIEW & RATING
// ═════════════════════════════════════════════════════════════════════════════

model Review {
  id              Int      @id @default(autoincrement())
  userId          String
  courseId        Int
  rating          Int      // 1-5 bintang
  comment         String?
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Todo {
  id              Int      @id @default(autoincrement())
  userId          String
  task            String
  isCompleted     Boolean  @default(false)
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assignment {
  id              Int      @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  dueDate         DateTime
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id              Int      @id @default(autoincrement())
  assignmentId    Int
  userId          String
  filePath        String?
  content         String?
  grade           String?
  feedback        String?
  status          String   @default("submitted")
  companyCode     String   @default("LEARNIFY")
  status_code     Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
}

model Recording {
  id              Int      @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  videoUrl        String
  duration        String?
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Resource {
  id              Int      @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  fileUrl         String
  fileType        String
  fileSize        String?
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Schedule {
  id              Int      @id @default(autoincrement())
  courseId        Int
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  location        String?
  companyCode     String   @default("LEARNIFY")
  status          Int      @default(1)
  isDeleted       Int      @default(0)
  createdBy       String   @default("SYSTEM")
  createdDate     DateTime @default(now())
  lastUpdatedBy   String   @default("SYSTEM")
  lastUpdatedDate DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}
